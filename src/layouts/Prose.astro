---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---
<div class:list={['prose', className]}>
  <slot />
</div>

<style>
  .prose {
    max-width: var(--prose-max-width);
    font-size: var(--prose-body-size);
    line-height: var(--prose-body-leading);
    color: var(--color-text-primary);
  }

  /* Headings */
  .prose :global(h1) {
    font-size: var(--font-size-3xl);
    font-weight: var(--prose-h-weight);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6);
  }
  .prose :global(h2) {
    font-size: var(--font-size-2xl);
    font-weight: var(--prose-h-weight);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    margin: var(--space-10) 0 var(--space-4);
  }
  .prose :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: var(--prose-h-weight);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: var(--space-8) 0 var(--space-3);
  }
  .prose :global(h4) {
    font-size: var(--font-size-lg);
    font-weight: var(--prose-h-weight);
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
    margin: var(--space-6) 0 var(--space-2);
  }

  /* Body copy */
  .prose :global(p) { margin: 0 0 var(--space-4); }

  /* Links */
  .prose :global(a) {
    color: var(--color-accent-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) { color: var(--color-accent-hover); }

  /* Inline code */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: var(--prose-code-size);
    background: var(--color-surface-subtle);
    border: 1px solid var(--color-border);
    padding: var(--space-0-5) var(--space-1);
    border-radius: var(--radius-sm);
  }

  /* Code blocks */
  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: 0 0 var(--space-6);
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    font-size: var(--prose-code-size);
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-4);
    padding-inline-start: var(--space-6);
  }
  .prose :global(li) { margin-block-start: var(--space-1); }

  /* Blockquote */
  .prose :global(blockquote) {
    border-inline-start: 3px solid var(--color-accent);
    margin-inline: 0;
    padding-inline-start: var(--space-4);
    color: var(--color-text-secondary);
    font-style: italic;
    margin-block: var(--space-6);
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-block-start: 1px solid var(--color-border);
    margin-block: var(--space-8);
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: 0 0 var(--space-6);
  }
  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    text-align: start;
  }
  .prose :global(th) {
    background: var(--color-surface-subtle);
    font-weight: var(--font-weight-semibold);
  }

  /* KaTeX math blocks */
  .prose :global(.katex-display) {
    overflow-x: auto;
    margin-block: var(--space-6);
    padding-block: var(--space-2);
  }
</style>
